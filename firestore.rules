rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write to users collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Allow read/write to passwords collection
    match /passwords/{userId} {
      allow read, write: if true;
    }

    // Allow read/write to foods collection
    match /foods/{foodId} {
      allow read, write: if true;
    }

    // Allow read/write to orders collection
    match /orders/{orderId} {
      allow read, write: if true;
    }
  }
}
