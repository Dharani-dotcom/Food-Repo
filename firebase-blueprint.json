{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "Password": {
      "title": "Password",
      "description": "Hashed password for auth",
      "type": "object",
      "properties": {
        "passwordHash": { "type": "string" },
        "password_hash": { "type": "string" }
      },
      "required": ["passwordHash"]
    },
    "Food": {
      "title": "Food",
      "description": "Food item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "available": { "type": "boolean" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Food order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "foodItems": { "type": "array" },
        "totalQuantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "deliveryAddress": { "type": "string" },
        "phone": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["Pending", "Paid", "Refunded"] },
        "orderStatus": { "type": "string", "enum": ["Pending", "Preparing", "Out for Delivery", "Delivered", "Cancelled"] },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "foodItems", "totalQuantity", "totalPrice", "deliveryAddress", "phone"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "passwords/{userId}": {
      "schema": "Password",
      "description": "Collection of password hashes mapped to user IDs"
    },
    "foods/{foodId}": {
      "schema": "Food",
      "description": "Collection of foods"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    }
  }
}
